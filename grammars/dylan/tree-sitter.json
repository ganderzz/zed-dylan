{
  "grammars": [
    {
      "name": "dylan",
      "scope": "source.dylan",
      "path": ".",
      "file-types": ["dylan"],
      "injection-regex": "^dylan$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Dylan language (lexical, for syntax highlighting)",
    "links": {
      "repository": "https://github.com/dylan/tree-sitter-dylan"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false
  }
}
